# Legacy Nx monorepo tooling (unplugin-auto-import, Nx 19.x lockfile
# parser, etc.) assumes npm/yarn-classic flat node_modules hoisting.
# Without this, transitive deps like @vueuse/core aren't resolvable
# from nested plugin code that does a bare `require()` instead of
# walking up from the consuming package.
shamefully-hoist=true
